* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    min-height: 100vh;
    padding: 20px;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    background: white;
    border-radius: 20px;
    padding: 40px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    text-align: center;
}

/* Landing Page */
.landing-page h1 {
    font-size: 3em;
    color: #667eea;
    margin-bottom: 10px;
}

.landing-page p {
    font-size: 1.2em;
    color: #666;
    margin-bottom: 40px;
}

.role-selection {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
}

/* Buttons */
.btn {
    padding: 12px 30px;
    font-size: 1em;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-weight: bold;
}

.btn-parent {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
}

.btn-parent:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
}

.btn-child {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    color: white;
}

.btn-child:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(245, 87, 108, 0.4);
}

.btn-add {
    background: #4caf50;
    color: white;
}

.btn-add:hover {
    background: #45a049;
}

.btn-back {
    background: #ddd;
    color: #333;
    padding: 8px 15px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-weight: bold;
}

/* Dashboard */
.dashboard {
    max-width: 1200px;
    margin: 0 auto;
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
}

.dashboard header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 30px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.dashboard header h1 {
    font-size: 2em;
}

.dashboard main {
    padding: 30px 20px;
}

.dashboard section {
    margin-bottom: 40px;
    background: #f9f9f9;
    padding: 25px;
    border-radius: 15px;
    border-left: 5px solid #667eea;
}

.dashboard section h2 {
    color: #333;
    margin-bottom: 20px;
    font-size: 1.5em;
}

/* Forms */
.form-group {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
}

.form-group input,
.form-group select {
    padding: 10px 15px;
    border: 2px solid #ddd;
    border-radius: 8px;
    font-size: 1em;
    flex: 1;
    min-width: 200px;
}

.form-group input:focus,
.form-group select:focus {
    outline: none;
    border-color: #667eea;
}

/* Tasks List */
.tasks-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
}

.task-card {
    background: white;
    border: 2px solid #eee;
    border-radius: 12px;
    padding: 20px;
    transition: all 0.3s ease;
}

.task-card:hover {
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
    border-color: #667eea;
}

.task-card h3 {
    color: #333;
    margin-bottom: 10px;
}

.task-card .task-type {
    display: inline-block;
    padding: 5px 10px;
    border-radius: 20px;
    font-size: 0.85em;
    margin-bottom: 10px;
}

.task-type.chore {
    background: #ffe4b5;
    color: #cc8800;
}

.task-type.learning {
    background: #e3f2fd;
    color: #1976d2;
}

.task-points {
    font-size: 1.3em;
    color: #4caf50;
    font-weight: bold;
    margin-bottom: 10px;
}

.task-checkbox {
    width: 20px;
    height: 20px;
    cursor: pointer;
    margin-right: 10px;
}

.task-actions {
    display: flex;
    gap: 10px;
    margin-top: 10px;
}

.task-actions button {
    flex: 1;
    padding: 8px 12px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: bold;
}

.btn-complete {
    background: #4caf50;
    color: white;
}

.btn-delete {
    background: #f44336;
    color: white;
}

/* Points Display */
.points-card,
.streak-card {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 30px;
    border-radius: 15px;
    text-align: center;
}

.points-card h2,
.streak-card h2 {
    font-size: 1.3em;
    margin-bottom: 15px;
}

.points-value {
    font-size: 3em;
    font-weight: bold;
    margin: 10px 0;
}

/* Streak Bar */
.streak-bar {
    background: rgba(255, 255, 255, 0.3);
    height: 30px;
    border-radius: 15px;
    overflow: hidden;
    margin: 15px 0;
}

.streak-fill {
    background: #4caf50;
    height: 100%;
    transition: width 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: bold;
}

#streakText {
    margin-top: 10px;
}

/* Badges */
.badges-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 15px;
}

.badge {
    background: white;
    border: 2px solid #ffc107;
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
}

.badge:hover {
    transform: scale(1.1);
    box-shadow: 0 8px 20px rgba(255, 193, 7, 0.3);
}

.badge-icon {
    font-size: 2.5em;
    margin-bottom: 10px;
}

.badge-name {
    font-weight: bold;
    color: #333;
}

.badge-locked {
    opacity: 0.5;
    background: #f0f0f0;
    border-color: #ddd;
}

/* Children Stats */
.children-stats {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 20px;
}

.child-stat {
    background: white;
    border: 2px solid #eee;
    border-radius: 12px;
    padding: 20px;
}

.child-stat h3 {
    color: #667eea;
    margin-bottom: 10px;
}

.child-stat .stat-value {
    font-size: 2em;
    font-weight: bold;
    color: #4caf50;
    margin: 10px 0;
}

/* Responsive Design */
@media (max-width: 768px) {
    .container {
        padding: 20px;
    }

    .dashboard header {
        flex-direction: column;
        gap: 15px;
        text-align: center;
    }

    .dashboard header h1 {
        font-size: 1.5em;
    }

    .landing-page h1 {
        font-size: 2em;
    }

    .role-selection {
        flex-direction: column;
    }

    .btn {
        width: 100%;
    }

    .form-group {
        flex-direction: column;
    }

    .form-group input,
    .form-group select {
        min-width: 100%;
    }

    .tasks-list {
        grid-template-columns: 1fr;
    }

    .points-value {
        font-size: 2em;
    }
}
