  </div>

  <!-- CHORE LIST VIEW (Parent) -->
  <div class="view" id="view-chores">
    <div class="page-title">
      <h1>Manage Chores</h1>
      <p>✦ Create, Edit &amp; Assign Tasks ✦</p>
    </div>

    <!-- Parent manage panel -->
    <div id="parent-chore-panel">
      <div class="manage-grid">
        <!-- Task Library -->
        <div class="wood-card">
          <div class="card-title">✦ Choose from Task Library ✦</div>
          <button class="quick-add-btn" onclick="quickAddAll()">➕ Quick Add +</button>
          <div class="task-library-grid">
            <div class="library-item" onclick="selectLibraryTask('Clean Room','🛏️')"><span class="icon">🛏️</span>Clean Room</div>
            <div class="library-item" onclick="selectLibraryTask('Do Homework','📚')"><span class="icon">📚</span>Do Homework</div>
            <div class="library-item" onclick="selectLibraryTask('Wash Dishes','🍽️')"><span class="icon">🍽️</span>Wash Dishes</div>
            <div class="library-item" onclick="selectLibraryTask('Take Out Trash','🗑️')"><span class="icon">🗑️</span>Take Out Trash</div>
            <div class="library-item" onclick="selectLibraryTask('Cook Dinner','🍳')"><span class="icon">🍳</span>Cook Dinner</div>
            <div class="library-item" onclick="selectLibraryTask('Feed the Pet','🐾')"><span class="icon">🐾</span>Feed the Pet</div>
