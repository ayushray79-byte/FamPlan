            <div class="assign-avatars">
              <button class="child-avatar-btn selected" title="Oliver" onclick="toggleAssign(this)">👦</button>
              <button class="child-avatar-btn" title="Emma" onclick="toggleAssign(this)">👧</button>
              <button class="child-avatar-btn" title="Leo" onclick="toggleAssign(this)">🧒</button>
