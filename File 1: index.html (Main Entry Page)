          <div class="card-title" style="margin-top:12px;">📝 Today's Task List</div>
          <div id="today-tasks">
            <div class="task-list-item"><div class="task-check">✓</div>Clean Your Room<div class="task-xp">⭐50 🪙</div></div>
            <div class="task-list-item"><div class="task-check">✓</div>Do Homework<div class="task-xp">⭐50 🪙</div></div>
            <div class="task-list-item"><div class="task-check">✓</div>Cook Dinner<div class="task-xp">⭐70 🪙</div></div>
            <div class="task-list-item"><div class="task-check">✓</div>Feed the Pet<div class="task-xp">⭐70 🪙</div></div>
          </div>
        </div>

        <!-- Create Custom Task -->
        <div class="wood-card">
          <div class="card-title">✦ Create Custom Task ✦</div>
          <div class="form-group">
            <label>Task Name:</label>
            <input type="text" id="task-name" placeholder="Enter task name">
          </div>
          <div class="form-group">
            <label>Description:</label>
            <textarea id="task-desc" placeholder="Write a description..."></textarea>
          </div>
          <div class="form-group">
            <label>Set Reward:</label>
            <div class="reward-row">
              <div class="reward-chip">🌟 <input type="number" value="50" min="10" max="200" style="width:50px; border:none; background:transparent; font-family:inherit; font-weight:800; font-size:13px;"> XP</div>
              <div class="reward-chip">🪙 <input type="number" value="25" min="5" max="100" style="width:50px; border:none; background:transparent; font-family:inherit; font-weight:800; font-size:13px;"> Coins</div>
