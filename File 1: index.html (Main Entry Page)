          </div>
          <button class="btn-green" onclick="addTask()">✅ Add Task</button>
          <div style="display:flex; gap:10px; margin-top:10px;">
            <button class="btn-green" style="background: linear-gradient(180deg, #ff8c42, #e5631e);" onclick="showView('chores')">📌 Assign Tasks</button>
            <button class="btn-green" style="background: linear-gradient(180deg, var(--sky), var(--sky-dark));" onclick="showToast('Calendar view coming soon!')">📅 View Calendar</button>
          </div>
        </div>
      </div>

      <!-- Review claimed task -->
      <div class="review-card">
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:10px;">
          <h3>🔍 Review Claimed Task</h3>
          <span class="badge badge-orange">Pending Review</span>
        </div>
        <p style="font-size:14px; font-weight:700; color:var(--text-light);">Task: <strong>Clean Your Room</strong> — claimed by Emma (Level 3)</p>
        <div class="review-photo">🛏️</div>
        <p style="font-size:13px; color:var(--text-light); margin-bottom:8px;">Photo submitted as proof. Approve to reward Emma with ⭐50 XP + 🪙25 Coins.</p>
        <div class="review-btns">
          <button class="btn-approve" onclick="approveTask()">✅ Approve Task</button>
          <button class="btn-cancel" onclick="cancelTask()">✖ Cancel Task</button>
        </div>
      </div>
    </div>
  </div>

  <!-- CHILD TASK VIEW (shown when child role active) -->
  <div style="display:none" id="child-task-view">
    <div class="page-title">
      <h1>Complete Your Tasks!</h1>
      <p>⭐ Earn Rewards &amp; Have Fun! ⭐</p>
    </div>

    <div class="stats-bar">
      <div class="stat-chip">📋 Today's Tasks: <strong>5</strong></div>
      <div class="stat-chip">⭐ This Week: <strong>8/12</strong></div>
      <div class="stat-chip" style="flex:1; min-width:200px;">
        🔺 XP to Level Up
        <div class="xp-progress-bar">
          <div class="xp-fill" id="xp-bar" style="width: 60%;"></div>
        </div>
      </div>
    </div>

    <div class="task-cards-grid" id="child-task-cards">
      <!-- Cards injected by JS -->
    </div>
  </div>

  <!-- REWARDS VIEW -->
  <div class="view" id="view-rewards">
    <div class="page-title">
      <h1>Unlock Rewards!</h1>
      <p>⭐ Reach Goals &amp; Collect Prizes! ⭐</p>
    </div>

    <div class="wood-card" style="margin-bottom:16px;">
      <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
        <span style="font-size:14px; font-weight:700;">⭐ XP Progress:</span>
        <div class="xp-progress-bar" style="flex:1; min-width:150px;">
          <div class="xp-fill" style="width:50%;"></div>
        </div>
        <span style="font-size:14px; font-weight:800; color:var(--gold);">250 / 500 XP</span>
      </div>
      <p style="font-size:12px; font-weight:600; color:var(--text-light); text-align:center; margin-top:6px;">✦ Earn XP to unlock fun rewards! ✦</p>
    </div>

    <div class="rewards-grid">
      <div class="reward-card unlocked">
        <div class="reward-card-cost">⭐ 200 XP</div>
        <div class="reward-card-img">🍫</div>
        <div class="reward-card-body">
          <div class="reward-card-name">Hanuta Treats!</div>
          <div class="reward-card-desc">Collect 2 Hanuta Snacks!</div>
          <button class="btn-green" style="font-size:13px; padding:8px;" onclick="claimReward(this,'Hanuta Treats')">✅ Claim!</button>
        </div>
      </div>
      <div class="reward-card">
        <div class="reward-card-cost">⭐ 500 XP</div>
        <div class="reward-card-img">🎬</div>
        <div class="reward-card-body">
          <div class="reward-card-name">Movie Night!</div>
          <div class="reward-card-desc">Enjoy a Family Movie!</div>
          <button class="btn-green" style="font-size:13px; padding:8px; background: linear-gradient(180deg,#aaa,#888);" disabled>🔒 500 XP</button>
        </div>
      </div>
      <div class="reward-card locked">
        <div class="reward-card-cost">⭐ 1000 XP</div>
        <div class="reward-card-img">🚗</div>
        <div class="reward-card-body">
          <div class="reward-card-name">New Toy!</div>
          <div class="reward-card-desc">Get an RC Car Toy!</div>
          <button class="btn-green" style="font-size:13px; padding:8px; background: linear-gradient(180deg,#aaa,#888);" disabled>🔒 1000 XP</button>
        </div>
      </div>
    </div>

    <div class="ultimate-banner">
      <div class="icon">🎡</div>
      <div>
        <h3>🏆 Ultimate Reward!</h3>
        <p>⭐ 1500 XP — Theme Park Adventure!</p>
      </div>
    </div>
  </div>

  <!-- LEADERBOARD VIEW -->
  <div class="view" id="view-leaderboard">
    <div class="page-title">
      <h1>🏆 Leaderboard</h1>
      <p>Who's the Chore Champion this week?</p>
    </div>

    <div class="wood-card" style="margin-bottom:16px;">
      <div class="card-title">📅 Weekly Progress</div>
      <div class="week-days" style="justify-content:center; margin-bottom:12px;">
        <div class="day-dot done">M</div>
        <div class="day-dot done">T</div>
        <div class="day-dot done">W</div>
        <div class="day-dot today">T</div>
        <div class="day-dot">F</div>
        <div class="day-dot">S</div>
        <div class="day-dot">S</div>
      </div>
    </div>

    <div class="wood-card">
      <div class="card-title">⭐ All-Time Rankings</div>
      <ul class="leaderboard-list">
        <li class="lb-item" style="border-color: var(--gold); background: linear-gradient(135deg, #fffbec, #fff9e0);">
          <div class="lb-rank gold">🥇</div>
          <div class="lb-avatar">👦</div>
          <div><div class="lb-name">Oliver</div><div class="lb-level">Level 4 · 28 tasks done</div></div>
          <div class="lb-score">⭐ 1,350</div>
        </li>
        <li class="lb-item">
          <div class="lb-rank silver">🥈</div>
          <div class="lb-avatar">👧</div>
          <div><div class="lb-name">Emma</div><div class="lb-level">Level 3 · 24 tasks done</div></div>
          <div class="lb-score">⭐ 1,250</div>
        </li>
        <li class="lb-item">
          <div class="lb-rank bronze">🥉</div>
          <div class="lb-avatar">🧒</div>
          <div><div class="lb-name">Leo</div><div class="lb-level">Level 2 · 18 tasks done</div></div>
