</main>

<!-- ROLE TOGGLE -->
<div class="role-toggle">
  <div style="font-size:11px; text-align:right; color:var(--text-light); font-weight:700;">Switch view:</div>
  <button class="role-btn parent-btn active-role" onclick="setRole('parent')">👩 Parent View</button>
  <button class="role-btn child-btn" onclick="setRole('child')">👧 Child View (Emma)</button>
</div>

<!-- COMPLETION POPUP -->
<div class="popup-overlay" id="popup">
  <div class="popup">
    <div style="font-size:48px; margin-bottom:8px;">🎉</div>
    <div class="popup-title">Task Complete!</div>
    <p style="font-size:14px; color:var(--text-light); font-weight:600;">Great job! You earned:</p>
    <div class="popup-rewards">
      <div class="popup-reward-item">⭐ 50 XP</div>
      <div class="popup-reward-item">🪙 25</div>
    </div>
    <div class="popup-btns">
      <button class="btn-collect" onclick="closePopup()">🎁 Collect!</button>
      <button class="btn-next" onclick="closePopup()">➡ Next Task</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
let role = 'parent';
let xp = 1250;

const childTasks = [
  { name: 'Clean Your Room', icon: '🛏️', xp: 50, coins: 25, done: false },
  { name: 'Do Homework', icon: '📚', xp: 50, coins: 25, done: true },
  { name: 'Feed the Pet', icon: '🐾', xp: 70, coins: 30, done: true },
  { name: 'Wash Dishes', icon: '🍽️', xp: 60, coins: 28, done: false },
  { name: 'Take Out Trash', icon: '🗑️', xp: 40, coins: 20, done: false },
];

function renderChildTasks() {
  const container = document.getElementById('child-task-cards');
  container.innerHTML = childTasks.map((t, i) => `
    <div class="task-card">
      <div class="task-card-img" style="background: ${t.done ? 'linear-gradient(135deg,#d4f7de,#a0e8b4)' : 'linear-gradient(135deg,#c8e6ff,#a0d4f5)'}">
        <span style="font-size:56px;">${t.icon}</span>
        <div class="star-badge">⭐ ${t.xp}</div>
      </div>
      <div class="task-card-body">
        <div class="task-card-name">${t.name}</div>
        ${!t.done ? `<button class="btn-photo" onclick="showToast('📷 Camera would open here!')">📷 Take Photo</button>` : ''}
        <button class="btn-done ${t.done ? 'completed' : ''}" onclick="markDone(${i})" ${t.done ? 'disabled' : ''}>
          ${t.done ? '✅ Task Done!' : '✓ Mark Done'} <span style="margin-left:auto;">⭐${t.xp}</span>
        </button>
      </div>
    </div>
  `).join('');
}

function markDone(i) {
  childTasks[i].done = true;
  renderChildTasks();
  xp += childTasks[i].xp;
  document.getElementById('xp-display').textContent = xp.toLocaleString();
  document.getElementById('popup').classList.add('show');
}

function closePopup() {
  document.getElementById('popup').classList.remove('show');
}

function showView(view) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('view-' + view).classList.add('active');
  document.querySelector(`[data-view="${view}"]`).classList.add('active');

  if (view === 'chores' && role === 'child') {
    document.getElementById('parent-chore-panel').style.display = 'none';
    document.getElementById('child-task-view').style.display = 'block';
    renderChildTasks();
  } else if (view === 'chores') {
    document.getElementById('parent-chore-panel').style.display = 'block';
    document.getElementById('child-task-view').style.display = 'none';
  }
}

function setRole(r) {
  role = r;
  document.querySelectorAll('.role-btn').forEach(b => b.classList.remove('active-role'));
  if (r === 'parent') {
    document.querySelector('.parent-btn').classList.add('active-role');
    document.getElementById('user-avatar').textContent = '👩';
    document.getElementById('user-name').textContent = 'Welcome, Sarah!';
    document.getElementById('parent-notification').style.display = 'flex';
  } else {
    document.querySelector('.child-btn').classList.add('active-role');
    document.getElementById('user-avatar').textContent = '👧';
    document.getElementById('user-name').textContent = 'Emma | Level 3';
    document.getElementById('parent-notification').style.display = 'none';
  }
  // Refresh chore view if currently visible
  const choreView = document.getElementById('view-chores');
  if (choreView.classList.contains('active')) showView('chores');
  showToast(r === 'parent' ? '👩 Switched to Parent view' : '👧 Switched to Emma\'s view');
}

function selectLibraryTask(name, icon) {
  document.getElementById('task-name').value = name;
  showToast(`${icon} "${name}" loaded into form!`);
}

function quickAddAll() {
  showToast('✅ All library tasks added to today\'s list!');
}

function toggleAssign(btn) {
  btn.classList.toggle('selected');
}

function addTask() {
  const name = document.getElementById('task-name').value.trim();
  if (!name) { showToast('⚠️ Please enter a task name!'); return; }
  const list = document.getElementById('today-tasks');
  const item = document.createElement('div');
  item.className = 'task-list-item';
  item.innerHTML = `<div class="task-check" style="background:var(--sky)">+</div>${name}<div class="task-xp">⭐50 🪙</div>`;
  list.appendChild(item);
  document.getElementById('task-name').value = '';
  document.getElementById('task-desc').value = '';
  showToast(`✅ "${name}" added!`);
}

function approveTask() {
  showToast('✅ Task approved! Emma earned ⭐50 XP + 🪙25 Coins');
}

function cancelTask() {
  showToast('✖ Task cancelled. Emma will be notified.');
}

function claimReward(btn, name) {
  btn.textContent = '🎉 Claimed!';
  btn.disabled = true;
  btn.style.background = 'linear-gradient(180deg, #aaa, #888)';
  showToast(`🎁 "${name}" reward claimed!`);
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}
</script>
</body>
</html>
